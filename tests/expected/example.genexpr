Abs(x) {
    History prev(0);
    out1 = x > 0 ? x : 0;
    prev = out1;
}

Clamp(x, lo, hi) {
    if (x < lo) {
        out1 = lo;
    } else {
        out1 = x;
    }
}

Sum(n) {
    History total(0);
    History i(0);
    while (i < n) {
        total = total + i;
        i = i + 1;
        out1 = total;
    }
}

