require("math");

foo(x,lo,hi){
if(x<lo){
return lo;
}
else if(x>hi ){
return hi ;
}
else{
 return x;
}
}

bar(input,a0,a1,a2,b1,  b2){
    History x1(0.0), x2(0.0), y1(0.0), y2(0.0);

	tmp = input * a0 + x1*a1 + x2 * a2 -(y1 *b1 +y2 *b2);
	x2 = x1;
	x1 = input; y2 = y1; y1 = tmp;
return tmp;
}
average(inputSample,windowSizeInSamples)
{
    Delay lastValues(samplerate,interp= "none");
    History accumulation(0);
    History windowSizeLast(0); History count(0);

    // Reset accumulation and count when window size changes
    if (windowSizeLast != windowSizeInSamples) {
        accumulation = 0;
        count = 0;
        windowSizeLast = windowSizeInSamples;
    }

    count = minimum(count, windowSizeInSamples);
    if (count==windowSizeInSamples) {
        accumulation -= lastValues.read(count); count -=1;
    }

    accumulation += inputSample;
    lastValues.write(inputSample);
    count += 1;
    return accumulation / count;
}

/* running maximum with optional decay */
runningMax(x,decay){
History peak(0);
peak=peak>x?peak*decay:x;
return peak;
}

countUp(limit){
History n(0);
while(n<limit){
n+=1;
}
return n;
}

countDown(start){
start-=1;
while(start>0){
start-=1;
}
return start;
}

firstBelow(threshold,n){
for(i=0;i<n;i+=1){
if(in1<threshold){
break;
}
if(in1>threshold*2){
continue;
}
}
return i;
}

swapPair(a,b){
a,b=b,a;
return a+b;
}

polyTest(a,b){
buffer buf(1024);
data tbl(512);
x=a==pb;
y=a!=pb;
z=a<pb||a>pb;
w=a&&!b;
return x+y+z+w;
}

out1=foo(in1,0.0,1.0);
out2=bar(in2,0.5,0.5,0,0.25,0.75);
